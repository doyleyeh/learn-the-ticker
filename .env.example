# Learn the Ticker local backend/API placeholders.
# Copy to .env only for local experiments. Never commit filled values.

APP_ENV=local
PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local Docker Compose default. Production should use Secret Manager or deployment-managed secrets.
DATABASE_URL=postgresql://learn_the_ticker:learn_the_ticker@localhost:5432/learn_the_ticker
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_POOL_PRE_PING=false
DATABASE_ECHO_SQL=false
DATABASE_MIGRATIONS_ENABLED=false

# Top-500 universe manifest. Local implementation should prefer the repo file when present.
TOP500_UNIVERSE_MANIFEST_URI=data/universes/us_common_stocks_top500.current.json

# LLM defaults. CI and tests must keep live generation disabled.
LLM_PROVIDER=mock
LLM_LIVE_GENERATION_ENABLED=false
LLM_VALIDATION_RETRY_COUNT=1
LLM_REASONING_SUMMARY_ONLY=true
LLM_CHAT_CACHE_TTL_SECONDS=86400

# OpenRouter placeholders. Keep actual values only in server-side env or Secret Manager.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_FREE_MODEL_ORDER=openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_PAID_FALLBACK_MODEL=deepseek/deepseek-v3.2
OPENROUTER_PAID_FALLBACK_ENABLED=false
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_TITLE=Learn the Ticker

# Optional structured enrichment provider placeholders. Do not use in CI.
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
TIINGO_API_KEY=
EODHD_API_KEY=

# Local object-storage placeholders for Docker Compose experiments.
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=learn-the-ticker-local
S3_ACCESS_KEY_ID=learn_the_ticker
S3_SECRET_ACCESS_KEY=
