# Cloud Run API placeholders. Store real values in Secret Manager or deployment-managed secrets.

APP_ENV=production
PORT=8080
CORS_ALLOWED_ORIGINS=https://example.vercel.app
DATABASE_URL=
MIGRATION_DATABASE_URL=
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO_SQL=false
DATABASE_MIGRATIONS_ENABLED=false
LOCAL_DURABLE_REPOSITORIES_ENABLED=true
LOCAL_DURABLE_REPOSITORIES_FAIL_FAST=true
LOCAL_DURABLE_REPOSITORY_COMMIT_ON_WRITE=true
LOCAL_DURABLE_OBJECT_NAMESPACE=learn-the-ticker-private-artifacts
ADMIN_ROUTES_ENABLED=false
TOP500_UNIVERSE_MANIFEST_URI=data/universes/us_common_stocks_top500.current.json
DATA_POLICY_MODE=lightweight
LIGHTWEIGHT_LIVE_FETCH_ENABLED=true
LIGHTWEIGHT_PROVIDER_FALLBACK_ENABLED=true
LIGHTWEIGHT_WEEKLY_NEWS_FETCH_ENABLED=true
LIGHTWEIGHT_FETCH_TIMEOUT_SECONDS=15
SEC_EDGAR_USER_AGENT=learn-the-ticker-api/0.1 contact@example.com
MARKET_NEWS_FETCH_ENABLED=true
MARKET_NEWS_LIVE_SOURCE_SMOKE_ENABLED=false
MARKET_NEWS_LIVE_SOURCE_REAL_FETCH_ENABLED=true
MARKET_NEWS_CACHE_TTL_HOURS=24
ECONOMIC_INDICATORS_LIVE_FETCH_ENABLED=true
ECONOMIC_INDICATORS_FETCH_TIMEOUT_SECONDS=15
LLM_PROVIDER=openrouter
LLM_LIVE_GENERATION_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_FREE_MODEL_ORDER=openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_PAID_FALLBACK_MODEL=deepseek/deepseek-v3.2
OPENROUTER_PAID_FALLBACK_ENABLED=false
OPENROUTER_SITE_URL=https://example.vercel.app
OPENROUTER_APP_TITLE=Learn the Ticker
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
MARKETAUX_API_KEY=
